# FinPremium — backend
# Copie este arquivo para backend/.env e preencha com os valores REAIS.
# O .env real NÃO vai para o git (já está no .gitignore).
# Peça os valores reais ao responsável por um canal seguro (1Password/Bitwarden/DM).

# --- Banco de dados (MongoDB Atlas) ---
MONGO_URL=mongodb+srv://USUARIO:SENHA@SEU_CLUSTER.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
DB_NAME=finpremium

# --- Frontend (CORS + cookies) ---
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# --- Auth ---
JWT_SECRET=gere_uma_string_aleatoria_forte
ADMIN_EMAIL=seu-email@exemplo.com
ADMIN_PASSWORD=defina_uma_senha_forte
COOKIE_SECURE=false

# --- Email (Resend) — https://resend.com/api-keys ---
RESEND_API_KEY=re_xxxxxxxx
SENDER_EMAIL=onboarding@resend.dev
OWNER_EMAIL=seu-email@exemplo.com

# --- Stripe — use sk_test_... localmente ---
STRIPE_API_KEY=sk_test_xxxxxxxx
# Rode `stripe listen --forward-to localhost:8000/api/webhook/stripe` e cole o whsec_...
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# --- Twilio WhatsApp Sandbox ---
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_PHONE_NUMBER=+14155238886
TWILIO_SMS_NUMBER=+1xxxxxxxxxx

# --- Emergent AI (opcional) ---
EMERGENT_AI_URL=
EMERGENT_AI_API_KEY=

# --- Visão para recibos/notas (Gemini OU OpenAI) ---
GEMINI_API_KEY=xxxxxxxx
GEMINI_VISION_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini

# --- Preenchido automaticamente ao subir o tunnel (sandbox WhatsApp) ---
TWILIO_WEBHOOK_PUBLIC_URL=
